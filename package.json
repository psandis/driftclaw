{
  "name": "driftclaw",
  "version": "0.1.0",
  "description": "Environment version drift detection CLI",
  "type": "module",
  "bin": {
    "driftclaw": "./dist/bin/driftclaw.js"
  },
  "scripts": {
    "cli": "tsx bin/driftclaw.ts",
    "dev": "tsx bin/driftclaw.ts",
    "build": "tsc",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "files": [
    "dist",
    "assets/driftclaw.png",
    "driftclaw.example.yaml",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "devops",
    "drift",
    "version",
    "environment",
    "deployment",
    "openclaw"
  ],
  "author": "psandis <petri.sandholm@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/psandis/driftclaw.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "ink": "^6.0.0",
    "react": "^19.2.4",
    "semver": "^7.7.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^22.13.14",
    "@types/react": "^19.2.14",
    "@types/semver": "^7.5.8",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
